# ════════════════════════════════════════════════════════════════
# Equity Research OS — environment template
# ────────────────────────────────────────────────────────────────
# 1. Copy this file to `.env`  (local development) and fill in real values.
# 2. `.env` is gitignored and must NEVER be committed.
# 3. On Vercel / production, set these in the platform's
#    Environment Variables UI instead of using a file.
# 4. Do NOT prefix any of these with NEXT_PUBLIC_ / VITE_ / REACT_APP_ —
#    that would expose the secret to the browser bundle. These are
#    server-side only.
# ════════════════════════════════════════════════════════════════

# ── Anthropic (Claude) — REQUIRED ───────────────────────────────
# Used for: thesis generation, skeptical analysis, final report synthesis.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI (GPT-4o-mini) — recommended ──────────────────────────
# Used for: SEC filing parsing, earnings extraction, supply-chain
# extraction, knowledge-graph building.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional overrides (sensible defaults applied if omitted) ────
# ANTHROPIC_PRIMARY_MODEL=claude-opus-4-8
# ANTHROPIC_FAST_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini
# OUTPUT_DIR=./output

# development | production  (auto-detected as production on Vercel)
APP_ENV=development
